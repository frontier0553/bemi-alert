generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ─────────────────────────────────────────────────────
model User {
  id          String        @id           // Supabase auth UUID
  email       String        @unique
  tier        String        @default("FREE")  // "FREE" | "PAID"
  linkCode    String?       // 6자리 텔레그램 연동 코드
  linkCodeExp DateTime?     // 연동 코드 만료 시각
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  settings    UserSettings?
}

// ── User Notification Settings ────────────────────────────────
model UserSettings {
  userId     String   @id
  user       User     @relation(fields: [userId], references: [id])
  coinFilter String?  // JSON 배열 ex) ["BTC","ETH"], null=전체
  pumpPct    Float?   // null=글로벌 기본값 사용
  dumpPct    Float?   // null=글로벌 기본값 사용
  updatedAt  DateTime @updatedAt
}

// ── PortOne Billing ───────────────────────────────────────────
model PortOneSubscription {
  id         String    @id @default(cuid())
  userId     String    @unique
  billingKey String    // 포트원 빌링키 (카드 등록 시 발급)
  pgProvider String?   // "TOSSPAYMENTS" | "KCP" 등
  startedAt  DateTime  @default(now())
  expiresAt  DateTime  // 현재 구독 만료일
  canceledAt DateTime? // 해지 처리 시각
}

// ── Visitor Tracking ─────────────────────────────────────────
model DailyVisit {
  date  String @id   // "YYYY-MM-DD"
  count Int    @default(0)
}

// ── Legacy (pre-STEP1) ───────────────────────────────────────
enum EventType {
  PUMP
  DUMP
}

model Event {
  id         String    @id @default(cuid())
  symbol     String
  type       EventType
  changePct  Float
  volumeMult Float
  price      Float
  detectedAt DateTime  @default(now())
}

// ── STEP 1: Short-window pump detection ─────────────────────
model Signal {
  id           String   @id @default(cuid())
  symbol       String
  type         String   @default("PUMP")
  changeWindow String
  changePct    Float
  volRatio     Float
  detectedAt   DateTime @default(now())
  metaJson     String?

  @@index([detectedAt])
  @@index([symbol, detectedAt])
}

model Cooldown {
  symbol      String
  type        String   @default("PUMP")   // "PUMP" | "DUMP"
  lastSentAt  DateTime
  lastMaxMove Float

  @@id([symbol, type])
}

model Settings {
  key   String @id
  value String
}

// ── Telegram Subscribers ─────────────────────────────────────
model Subscriber {
  id        String   @id @default(cuid())
  chatId    String   @unique
  username  String?
  firstName String?
  isActive  Boolean  @default(true)
  userId    String?  // 연동된 User ID (optional)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Futures Signals (Funding Rate / OI) ──────────────────────
model FuturesAlert {
  id          String   @id @default(cuid())
  symbol      String
  alertType   String   // "FUNDING" | "OI_SURGE" | "OI_DROP"
  value       Float    // funding rate (%) or OI change (%)
  markPrice   Float?   // funding 감지 시 mark price
  note        String?  // 부가 설명

  detectedAt  DateTime @default(now())

  @@index([detectedAt])
  @@index([symbol, detectedAt])
}

// ── Whale Flow Detection ─────────────────────────────────────
model WhaleEvent {
  id         String   @id @default(cuid())
  symbol     String
  direction  String   // "BUY" | "SELL" | "MIXED"
  tradeSize  Float    // largest single whale trade (USD)
  price      Float
  score      Int      // -100..+100
  whaleBuys  Int
  whaleSells Int
  type       String   // "ACCUMULATION" | "DUMP" | "NEUTRAL"
  detectedAt DateTime @default(now())

  @@index([detectedAt])
  @@index([symbol, detectedAt])
}
