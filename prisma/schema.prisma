generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Legacy (pre-STEP1) ───────────────────────────────────────
enum EventType {
  PUMP
  DUMP
}

model Event {
  id         String    @id @default(cuid())
  symbol     String
  type       EventType
  changePct  Float
  volumeMult Float
  price      Float
  detectedAt DateTime  @default(now())
}

// ── STEP 1: Short-window pump detection ─────────────────────
model Signal {
  id           String   @id @default(cuid())
  symbol       String
  type         String   @default("PUMP")
  changeWindow String
  changePct    Float
  volRatio     Float
  detectedAt   DateTime @default(now())
  metaJson     String?

  @@index([detectedAt])
  @@index([symbol, detectedAt])
}

model Cooldown {
  symbol      String   @id
  type        String   @default("PUMP")
  lastSentAt  DateTime
  lastMaxMove Float
}

model Settings {
  key   String @id
  value String
}

// ── Telegram Subscribers ─────────────────────────────────────
model Subscriber {
  id        String   @id @default(cuid())
  chatId    String   @unique
  username  String?
  firstName String?
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Futures Signals (Funding Rate / OI) ──────────────────────
model FuturesAlert {
  id          String   @id @default(cuid())
  symbol      String
  alertType   String   // "FUNDING" | "OI_SURGE" | "OI_DROP"
  value       Float    // funding rate (%) or OI change (%)
  markPrice   Float?   // funding 감지 시 mark price
  note        String?  // 부가 설명

  detectedAt  DateTime @default(now())

  @@index([detectedAt])
  @@index([symbol, detectedAt])
}

// ── Whale Flow Detection ─────────────────────────────────────
model WhaleEvent {
  id         String   @id @default(cuid())
  symbol     String
  direction  String   // "BUY" | "SELL" | "MIXED"
  tradeSize  Float    // largest single whale trade (USD)
  price      Float
  score      Int      // -100..+100
  whaleBuys  Int
  whaleSells Int
  type       String   // "ACCUMULATION" | "DUMP" | "NEUTRAL"
  detectedAt DateTime @default(now())

  @@index([detectedAt])
  @@index([symbol, detectedAt])
}
